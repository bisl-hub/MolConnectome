# .env.example
# Copy this file to .env and fill in the fields below.

# API Key for generating responses
OPENAI_API_KEY="your_api_key_here"

# Base URL for the LLM Endpoint (if using a custom endpoint, e.g. Ollama or local model)
LLM_BASE_URL="http://your_endpoint:11434/v1"

# The LLM model to query
LLM_MODEL_ID="openai/gpt-oss-120b"
